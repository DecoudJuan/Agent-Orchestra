workspace: ./project
llm:
  model: gpt-4.1
  embedding_model: text-embedding-3-small
permissions:
  read:
    deny: [".env", "**/*.pem", "secrets/**", "node_modules/**"]
  write:
    deny: [".github/**", "package-lock.json", ".git/**"]
commands:
  deny: ["rm -rf", "git push", "git reset --hard"]
  require_approval: ["npm install", "npm uninstall", "git commit"]
tools:
  # All discovered tools are enabled by default. Optionally restrict or extend:
  # enabled: [read_file, list_files, rag_search]   # allowlist (omit = all)
  disabled: []                                     # tool names to skip
  plugin_dirs: []                                  # extra dirs scanned for plugin modules
