OPENAI_API_KEY=your_openai_key_here
TAVILY_API_KEY=your_tavily_key_here        # optional: web_search returns an error message without it
LANGFUSE_PUBLIC_KEY=your_langfuse_pk_here  # optional: local JSONL traces are always written
LANGFUSE_SECRET_KEY=your_langfuse_sk_here  # optional
LANGFUSE_HOST=https://cloud.langfuse.com   # optional
